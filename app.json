{
  "expo": {
    "name": "CampusEyes",
    "slug": "campus-eyes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campuseyes.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CampusEyes needs camera access to detect objects and help with navigation",
        "NSLocationWhenInUseUsageDescription": "CampusEyes needs location access for navigation"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.campuseyes.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "CampusEyes needs camera access to detect objects and help with navigation"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CampusEyes needs location access for navigation"
        }
      ],
      "expo-font"
    ]
  }
}
